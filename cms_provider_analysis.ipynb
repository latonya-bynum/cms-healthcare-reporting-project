import os
import pandas as pd

# -------------------------------
# 1. Set File Path
# -------------------------------
base_path = os.getcwd()

file_path = os.path.join(
    base_path,
    '01_raw_data',
    'claims',
    'provider.csv'   # ✅ this is the correct file that worked
)

# -------------------------------
# 2. Load Data
# -------------------------------
df = pd.read_csv(file_path, low_memory=False)

# -------------------------------
# 3. Basic Data Checks
# -------------------------------
print("Shape:", df.shape)
print("\nColumns:\n", df.columns.tolist())
print("\nData Info:")
df.info()

# Preview
df.head()

# -------------------------------
# 4. Identify Relevant Columns
# -------------------------------
# (Based on your dataset structure)
service_column = 'Tot_Srvcs'
provider_column = 'Rndrng_NPI'

# Validate columns exist
if service_column not in df.columns:
    raise ValueError(f"{service_column} not found in dataset")

if provider_column not in df.columns:
    raise ValueError(f"{provider_column} not found in dataset")

# -------------------------------
# 5. Top Providers by Services
# -------------------------------
top_providers = (
    df.groupby(provider_column)[service_column]
      .sum()
      .reset_index()
      .sort_values(by=service_column, ascending=False)
      .head(10)
)

print("\nTop 10 Providers by Total Services:")
print(top_providers)

# -------------------------------
# 6. Save Output
# -------------------------------
output_path = os.path.join(base_path, '04_outputs')

# Create folder if it doesn't exist
os.makedirs(output_path, exist_ok=True)

output_file = os.path.join(output_path, 'top_providers.csv')

top_providers.to_csv(output_file, index=False)

print(f"\n✅ Output saved to: {output_file}")
